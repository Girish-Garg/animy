# Backend environment variables. Copy to .env and fill in real values.

# Server
PORT=5000
NODE_ENV=development
# Comma is not used — set the single deployed frontend origin:
FRONTEND_URL=https://app.animy.tech
# Optional extra CORS origins (comma-separated), e.g. other local ports:
# CORS_EXTRA_ORIGINS=http://localhost:3000,http://127.0.0.1:5173

# MongoDB
MONGO_URI=mongodb+srv://...

# Clerk (server)
CLERK_SECRET_KEY=sk_...
CLERK_PUBLISHABLE_KEY=pk_...

# External video generation API
Video_API_BASE_URL=https://...

# Email (Zoho SMTP) — ROTATE the old password; it was committed previously.
SMTP_HOST=smtppro.zoho.in
SMTP_PORT=465
SMTP_USER=contact@animy.tech
SMTP_PASS=
SMTP_FROM=AnimY <contact@animy.tech>

# Sentry (optional — leave unset to disable)
SENTRY_DSN=
